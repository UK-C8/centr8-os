{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'no build step needed — worker runs via tsx directly'"
  },
  "deploy": {
    "startCommand": "node node_modules/.bin/tsx workers/agent-worker.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
